import * as React from 'react';
import styles from './DirectoryHome.module.scss';


export interface IDirectoryHomeProps {
    employees: IEmployee[];
    onSelectEmployee: (employee: IEmployee) => void;
    onKudosClick: () => void;
}

export interface IEmployee {
    // Core Microsoft Graph User properties
    id: string;                          // Graph: id (unique identifier)
    displayName: string;                 // Graph: displayName
    givenName?: string;                  // Graph: givenName (first name)
    surname?: string;                    // Graph: surname (last name)
    jobTitle?: string;                   // Graph: jobTitle
    department?: string;                 // Graph: department
    officeLocation?: string;             // Graph: officeLocation
    city?: string;                       // Graph: city
    state?: string;                      // Graph: state
    country?: string;                    // Graph: country
    mail?: string;                       // Graph: mail (primary email)
    userPrincipalName?: string;          // Graph: userPrincipalName (UPN)
    mobilePhone?: string;                // Graph: mobilePhone
    businessPhones?: string[];           // Graph: businessPhones (array)

    // Manager relationship
    managerId?: string;                  // Custom: manager's id (from Graph manager endpoint)

    // Presence (from Graph Presence API)
    presence?: {
        availability?: string;           // Graph Presence: available, busy, away, offline, etc.
        activity?: string;               // Graph Presence: Available, InACall, InAMeeting, etc.
    };

    // Computed/Helper properties (not from Graph, computed client-side)
    initials?: string;                   // Computed from displayName or givenName/surname
    isOnline?: boolean;                  // Computed from presence.availability
}



export const DirectoryHome: React.FunctionComponent<IDirectoryHomeProps> = (props) => {
    const { employees, onSelectEmployee, onKudosClick } = props;
    const [viewMode, setViewMode] = React.useState<'grid' | 'list'>('grid');
    const [searchTerm, setSearchTerm] = React.useState('');

    const filteredEmployees = employees.filter(emp =>
        emp.displayName.toLowerCase().includes(searchTerm.toLowerCase()) ||
        (emp.jobTitle?.toLowerCase() || '').includes(searchTerm.toLowerCase()) ||
        (emp.department?.toLowerCase() || '').includes(searchTerm.toLowerCase())
    );

    return (
        <>
            {/* Search Section */}
            <div className={styles.searchSection}>
                <div className="container">
                    <div className={styles.searchBar}>
                        <input
                            type="text"
                            className={styles.searchInput}
                            placeholder="Search employees by name, title, or department..."
                            value={searchTerm}
                            onChange={(e) => setSearchTerm(e.target.value)}
                        />
                        <select className={styles.filterDropdown}>
                            <option>All Departments</option>
                            <option>Human Resources</option>
                            <option>Engineering</option>
                            <option>IT Department</option>
                        </select>
                        <select className={styles.filterDropdown}>
                            <option>All JobTitles</option>
                            <option>UX Designer</option>
                            <option>Developer</option>
                            <option>Microsoft 365 Specialist</option>
                        </select>
                    </div>
                </div>
            </div>

            {/* Alphabet Navigation */}
            <div className={styles.alphabetNav}>
                <div className="container">
                    <h3>Browse by Name</h3>
                    <div className={styles.letters}>
                        <div className={`${styles.letter} ${styles.star}`} title="Featured">⭐</div>
                        <div className={`${styles.letter} ${styles.active}`}>All</div>
                        {'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map(letter => (
                            <div key={letter} className={styles.letter}>{letter}</div>
                        ))}
                    </div>
                </div>
            </div>

            {/* Results Header */}
            <div className={styles.resultsHeader}>
                <div className="container">
                    <div className={styles.resultsInner}>
                        <div className={styles.resultsInfo}>
                            <h2>All Employees</h2>
                            <p>Showing {filteredEmployees.length} results</p>
                        </div>
                        <div className={styles.actionButtons}>
                            <button
                                className={`${styles.actionBtn} ${viewMode === 'grid' ? styles.active : ''}`}
                                onClick={() => setViewMode('grid')}
                            >
                                <span>Grid</span>
                            </button>
                            <button
                                className={`${styles.actionBtn} ${viewMode === 'list' ? styles.active : ''}`}
                                onClick={() => setViewMode('list')}
                            >
                                <span>List</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            {/* Employee Grid Section */}
            <div className={styles.employeeSection}>
                <div className="container">
                    <div className={`${styles.employeeGrid} ${viewMode === 'list' ? styles.listView : ''}`}>
                        {filteredEmployees.map(emp => (
                            <div key={emp.id} className={`${styles.employeeCard} ${viewMode === 'list' ? styles.listView : ''}`}>
                                <div className={styles.cardHeader}>
                                    <div
                                        className={styles.avatar}
                                        onClick={() => props.onSelectEmployee(emp)}
                                        title="View Profile"
                                    >
                                        {emp.initials}
                                        {emp.isOnline && <div className={styles.onlineStatus}></div>}
                                    </div>
                                    <div className={styles.employeeInfo}>
                                        <h3
                                            className={styles.employeeName}
                                            onClick={() => props.onSelectEmployee(emp)}
                                            title="View Profile"
                                        >
                                            {emp.name}
                                            <div className={styles.employeeCard}>
                                                <div className={styles.cardAvatar} style={{ background: `linear-gradient(135deg, hsl(${(emp.id.charCodeAt(0) * 137) % 360}, 70%, 60%) 0%, hsl(${(emp.id.charCodeAt(0) * 137 + 60) % 360}, 70%, 50%) 100%)` }}>
                                                    <span className={styles.cardName} onClick={() => onSelectEmployee(emp)}>{emp.displayName}</span>
                                                    {emp.initials}
                                                    <div className={`${styles.onlineIndicator} ${emp.isOnline ? styles.online : styles.offline}`}></div>
                                                </div>
                                                <div className={styles.cardContent}>
                                                    <div className={styles.cardInfo}>
                                                        <div className={styles.cardDepartment}>{emp.department || 'N/A'}</div>
                                                    </div>
                                                    <div className={styles.cardActions}>
                                                        <button className={styles.iconBtn} title="Email">✉️</button>
                                                        <button className={styles.iconBtn} title="Chat">💬</button>
                                                        <button className={styles.iconBtn} title="Call">📞</button>
                                                    </div>
                                                </div>
                                                <div className={styles.cardFooter}>
                                                    <div className={styles.cardLocation}>📍 {emp.city && emp.state ? `${emp.city}, ${emp.state}` : emp.officeLocation || 'N/A'}</div>
                                                    <div className={styles.cardContact}>
                                                        <div>✉️ {emp.mail || emp.userPrincipalName || 'N/A'}</div>
                                                        <div>📞 {emp.businessPhones?.[0] || emp.mobilePhone || 'N/A'}</div>
                                                    </div>
                                                </div>
                                            </div>
                        ))}
                                    </div>
                                </div>
                            </div>
        </>
                    );
};
